DATABASE_URL=postgresql://ticket:ticket@localhost:5432/ticketing
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
JWT_SECRET=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:3000

# Opcional. En Vercel (VERCEL=1) el valor por defecto es /tmp/ticketing-uploads.
# UPLOADS_DIR=/tmp/ticketing-uploads

# Opcional. Si están definidas, los adjuntos nuevos van a S3; el front usa URL prefirmada.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_NAME=
# S3_PRESIGN_PUT_EXPIRES=900
# S3_PRESIGN_GET_EXPIRES=3600